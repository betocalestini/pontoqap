# Database
DATABASE_URL=postgres://store:store@localhost:5432/store?sslmode=disable

# API
HTTP_ADDR=:8080
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=15s
HTTP_IDLE_TIMEOUT=60s
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Security
SESSION_SECRET=change-me-in-production-min-32-chars
CSRF_SECRET=change-me-csrf-min-32-chars
ENCRYPTION_KEY=change-me-32-byte-key-for-aes!!
ADMIN_MFA_REQUIRED=false

# Cookies
COOKIE_SECURE=false
STORE_SESSION_COOKIE=store_session
ADMIN_SESSION_COOKIE=admin_session
SESSION_TTL_STORE=24h
SESSION_TTL_ADMIN=8h

# App URLs
STORE_WEB_URL=http://localhost:5173
ADMIN_WEB_URL=http://localhost:5174

# Primeiro administrador (criado só se não existir system_admin no banco)
ADMIN_BOOTSTRAP_EMAIL=admin@loja.local
ADMIN_BOOTSTRAP_NAME=Administrador
ADMIN_BOOTSTRAP_PASSWORD=ChangeMe123!

# App
APP_ENV=development
LOG_LEVEL=debug

# Worker
WORKER_POLL_INTERVAL=5s
WORKER_ID=worker-1

# Payments — sandbox (padrão para CI e dev sem credenciais MP)
PAYMENT_PROVIDER=sandbox
PAYMENT_WEBHOOK_SECRET=sandbox-webhook-secret

# Mercado Pago Pix — descomente e preencha para testes com MP
# MERCADO_PAGO_WEBHOOK_SECRET=   # segredo do painel Webhooks (modo teste, evento Order); NÃO é o Access Token; recopie ao mudar o túnel
# PAYMENT_PROVIDER=mercadopago   # alias: mercado_pago
# MERCADO_PAGO_ENVIRONMENT=test
# MERCADO_PAGO_BASE_URL=https://api.mercadopago.com
# MERCADO_PAGO_ACCESS_TOKEN=       # Homologação: Testes → Credenciais de teste → Access Token. Produção só no go-live.
# MERCADO_PAGO_PUBLIC_KEY= 
# MERCADO_PAGO_APPLICATION_ID=
# MERCADO_PAGO_PIX_EXPIRATION=PT24H
# MERCADO_PAGO_REQUEST_TIMEOUT_SECONDS=10
# MERCADO_PAGO_TEST_AUTO_APPROVE=false   # true só em dev/test: payer APRO (aprovação automática Pix MP)
# MERCADO_PAGO_WEBHOOK_DEBUG=false       # true em development: loga captura + grava /tmp/mp-webhook-last.json (proibido em production)

# Storage — raiz do catálogo estático; uploads vão em {UPLOAD_DIR}/product-images/{slug}.ext
# Docker: monta backend/internal/catalog/static em /data/catalog-static
UPLOAD_DIR=internal/catalog/static

# E-mail (dev: Mailpit em localhost:1025, UI http://localhost:8025)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Store <noreply@store.local>"
STORE_WEB_URL=http://localhost:5173
DEFAULT_CUSTOMER_CREDIT_LIMIT_CENTS=50000
