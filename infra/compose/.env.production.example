# Exemplo — copie para .env.production no servidor (não commitar valores reais)
POSTGRES_USER=store
POSTGRES_PASSWORD=
POSTGRES_DB=store
DATABASE_URL=postgres://store:CHANGE@postgres:5432/store?sslmode=disable

DOMAIN=loja.example.com
ADMIN_DOMAIN=admin.loja.example.com
ACME_EMAIL=ops@example.com
CORS_ALLOWED_ORIGINS=https://loja.example.com,https://admin.loja.example.com

# Traefik (compose.traefik.yaml) — confira no Portainer a rede do container Traefik
TRAEFIK_NETWORK=traefik
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERT_RESOLVER=letsencrypt

SESSION_SECRET=
CSRF_SECRET=
ENCRYPTION_KEY=
PAYMENT_WEBHOOK_SECRET=
WORKER_ID=worker-1

# Imagens pré-buildadas (GHCR) — opcional; se definidas, deploy faz pull antes do up
# STORE_API_IMAGE=ghcr.io/SEU_ORG/store-platform-api:master
# STORE_WORKER_IMAGE=ghcr.io/SEU_ORG/store-platform-worker:master
# STORE_MIGRATE_IMAGE=ghcr.io/SEU_ORG/store-platform-migrate:master
# STORE_WEB_IMAGE=ghcr.io/SEU_ORG/store-platform-store-web:master
# STORE_ADMIN_WEB_IMAGE=ghcr.io/SEU_ORG/store-platform-admin-web:master
# USE_REGISTRY_IMAGES=true
