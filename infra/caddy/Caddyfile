# TLS e reverse proxy (Caddy)
# Defina DOMAIN e ACME_EMAIL no ambiente de produção.

{
	email {$ACME_EMAIL}
}

{$DOMAIN} {
	encode gzip
	header Strict-Transport-Security "max-age=31536000; includeSubDomains"

	handle /api/* {
		reverse_proxy api:8080
	}
	handle /health {
		reverse_proxy api:8080
	}
	handle /admin* {
		reverse_proxy admin-web:80
	}
	handle {
		reverse_proxy store-web:80
	}
}
