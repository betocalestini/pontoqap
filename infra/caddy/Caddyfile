# TLS e reverse proxy (Caddy)
# Variáveis: DOMAIN (loja), ADMIN_DOMAIN (painel), ACME_EMAIL

{
	email {$ACME_EMAIL}
}

{$DOMAIN} {
	encode gzip
	header Strict-Transport-Security "max-age=31536000; includeSubDomains"

	handle /api/* {
		reverse_proxy api:8080
	}
	handle /health {
		reverse_proxy api:8080
	}
	handle {
		reverse_proxy store-web:80
	}
}

{$ADMIN_DOMAIN} {
	encode gzip
	header Strict-Transport-Security "max-age=31536000; includeSubDomains"

	handle /api/* {
		reverse_proxy api:8080
	}
	handle {
		reverse_proxy admin-web:80
	}
}
